@page
@model MicroserviceWebApp.Pages.Basket.PaymentPendingModel
@{
    ViewData["Title"] = "Ödeme Beklemede";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-hourglass-split text-warning" style="font-size: 5rem;"></i>
                    </div>
                    <h2 class="fw-bold text-warning mb-3">Ödemeniz İşleniyor</h2>
                    <p class="text-muted mb-4">
                        Siparişiniz oluşturuldu ancak ödeme işleminiz henüz tamamlanmadı.
                        Ödeme durumunuz kontrol ediliyor.
                    </p>

                    <div class="alert alert-light border">
                        <small class="text-muted d-block mb-1">Sipariş Numarası</small>
                        <h5 class="mb-0 font-monospace">@Model.OrderId</h5>
                    </div>

                    <div class="row text-start my-4">
                        <div class="col-12">
                            <div class="d-flex align-items-start mb-3">
                                <i class="bi bi-check-circle text-success me-3 fs-5"></i>
                                <div>
                                    <h6 class="mb-1">Sipariş Oluşturuldu</h6>
                                    <small class="text-muted">Siparişiniz sistemimize kaydedildi.</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-start mb-3">
                                <i class="bi bi-hourglass-split text-warning me-3 fs-5"></i>
                                <div>
                                    <h6 class="mb-1">Ödeme İşleniyor</h6>
                                    <small class="text-muted">Ödeme işleminiz bankamız tarafından kontrol ediliyor.</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-start">
                                <i class="bi bi-clock text-muted me-3 fs-5"></i>
                                <div>
                                    <h6 class="mb-1">Bildirim Bekliyor</h6>
                                    <small class="text-muted">Sonuç e-posta adresinize gönderilecektir.</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-info-circle"></i>
                        <strong>Lütfen Bekleyin:</strong> Ödeme işleminiz genellikle birkaç dakika içinde tamamlanır.
                        Sayfayı kapatabilirsiniz, sonuç size e-posta ile bildirilecektir.
                    </div>

                    <hr class="my-4" />

                    <div class="d-grid gap-2">
                        <a asp-page="/Order/Index" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-seam"></i> Siparişlerimi Görüntüle
                        </a>
                        <a asp-page="/Course/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Alışverişe Devam Et
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-light text-center">
                    <small class="text-muted">
                        <i class="bi bi-info-circle"></i>
                        Sorularınız için destek ekibimizle iletişime geçebilirsiniz.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
