@page
@model MicroserviceWebApp.Pages.Basket.PaymentFailedModel
@{
    ViewData["Title"] = "Ödeme Başarısız";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-x-circle-fill text-danger" style="font-size: 5rem;"></i>
                    </div>
                    <h2 class="fw-bold text-danger mb-3">Ödeme Başarısız!</h2>
                    <p class="text-muted mb-4">
                        Maalesef ödeme işleminiz tamamlanamadı. Lütfen ödeme bilgilerinizi kontrol edip tekrar deneyiniz.
                    </p>

                    <div class="alert alert-light border">
                        <small class="text-muted d-block mb-1">Sipariş Numarası</small>
                        <h5 class="mb-0 font-monospace">@Model.OrderId</h5>
                    </div>

                    <div class="alert alert-danger">
                        <h6><i class="bi bi-exclamation-triangle"></i> Olası Nedenler:</h6>
                        <ul class="text-start mb-0">
                            <li>Kart bilgileri hatalı olabilir</li>
                            <li>Kartınızda yeterli bakiye bulunmuyor olabilir</li>
                            <li>Kartınız online ödemelere kapalı olabilir</li>
                            <li>Kart güvenlik kodu (CVV) yanlış girilmiş olabilir</li>
                            <li>Kartınızın son kullanma tarihi geçmiş olabilir</li>
                        </ul>
                    </div>

                    <div class="row text-start my-4">
                        <div class="col-12">
                            <div class="d-flex align-items-start mb-3">
                                <i class="bi bi-check-circle text-success me-3 fs-5"></i>
                                <div>
                                    <h6 class="mb-1">Sipariş Oluşturuldu</h6>
                                    <small class="text-muted">Siparişiniz sistemde kayıtlı ancak ödeme alınamadı.</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-start mb-3">
                                <i class="bi bi-x-circle text-danger me-3 fs-5"></i>
                                <div>
                                    <h6 class="mb-1">Ödeme Başarısız</h6>
                                    <small class="text-muted">Ödeme işleminiz gerçekleştirilemedi.</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-grid gap-2">
                        <a asp-page="/Basket/Checkout" class="btn btn-danger btn-lg">
                            <i class="bi bi-arrow-clockwise"></i> Tekrar Dene
                        </a>
                        <a asp-page="/Order/Index" class="btn btn-outline-primary">
                            <i class="bi bi-box-seam"></i> Siparişlerimi Görüntüle
                        </a>
                        <a asp-page="/Course/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Alışverişe Devam Et
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-light text-center">
                    <small class="text-muted">
                        <i class="bi bi-headset"></i>
                        Sorun devam ederse destek ekibimizle iletişime geçebilirsiniz.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
