@page

@model MicroserviceWebApp.Pages.Instructor.CreateCourseModel
@{
    ViewData["Title"] = "Yeni Kurs Oluştur";
    ViewData["Subtitle"] = "Öğrencilerinizle paylaşmak için yeni bir kurs oluşturun";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow">
                <div class="card-body">
                    <h2 class="card-title text-center mb-4">Yeni Kurs Oluştur</h2>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <form method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label asp-for="Input.CategoryId" class="form-label">Kategori</label>
                            <select asp-for="Input.CategoryId" asp-items="Model.Input.CategoryDropdownList" class="form-select">
                            </select>
                            <span asp-validation-for="Input.CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Name" class="form-label">Kurs Adı</label>
                            <input asp-for="Input.Name" class="form-control" placeholder="Kurs adını girin" />
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label">Açıklama</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Kurs açıklamasını girin"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Price" class="form-label">Fiyat ($)</label>
                            <input asp-for="Input.Price" class="form-control" type="number" step="0.01" placeholder="0.00" />
                            <span asp-validation-for="Input.Price" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Picture" class="form-label">Kurs Görseli</label>
                            <input asp-for="Input.Picture" id="picture-input" class="form-control" type="file" accept="image/*" />
                            <span asp-validation-for="Input.Picture" class="text-danger"></span>
                            <div id="picture-size-error" class="text-danger small mt-1" style="display:none;"></div>
                            <small class="form-text text-muted">Opsiyonel - JPEG, PNG veya GIF formatında (maksimum 5MB)</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Kurs Oluştur</button>
                            <a href="/Instructor/Courses" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const maxSizeBytes = 5 * 1024 * 1024;
            const input = document.getElementById('picture-input');
            const errorBox = document.getElementById('picture-size-error');
            const submitButton = document.querySelector('form button[type="submit"]');

            input.addEventListener('change', function () {
                const file = input.files && input.files[0];
                if (file && file.size > maxSizeBytes) {
                    errorBox.textContent = 'Görsel boyutu en fazla 5MB olabilir. Seçilen dosya ' +
                        (file.size / (1024 * 1024)).toFixed(1) + 'MB.';
                    errorBox.style.display = 'block';
                    input.value = '';
                    if (submitButton) submitButton.disabled = true;
                } else {
                    errorBox.style.display = 'none';
                    if (submitButton) submitButton.disabled = false;
                }
            });
        })();
    </script>
}
