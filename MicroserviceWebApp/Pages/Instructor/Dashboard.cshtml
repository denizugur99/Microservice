@page
@model MicroserviceWebApp.Pages.Instructor.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Hoş geldiniz! İşte performansınızın özeti";
}

<!-- İstatistik Kartları -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Toplam Kurs</p>
                        <h3 class="mb-0 fw-bold">@Model.TotalCourses</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-book text-primary" style="font-size: 2rem;"></i>
                    </div>
                </div>
                <small class="text-success">
                    <i class="bi bi-arrow-up"></i> %12 bu ay
                </small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Toplam Öğrenci</p>
                        <h3 class="mb-0 fw-bold">@Model.TotalStudents</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-people text-success" style="font-size: 2rem;"></i>
                    </div>
                </div>
                <small class="text-success">
                    <i class="bi bi-arrow-up"></i> %8 bu ay
                </small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Toplam Kazanç</p>
                        <h3 class="mb-0 fw-bold">@Model.TotalEarnings ₺</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-wallet2 text-warning" style="font-size: 2rem;"></i>
                    </div>
                </div>
                <small class="text-success">
                    <i class="bi bi-arrow-up"></i> %24 bu ay
                </small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Ortalama Puan</p>
                        <h3 class="mb-0 fw-bold">@Model.AverageRating</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-star-fill text-info" style="font-size: 2rem;"></i>
                    </div>
                </div>
                <small class="text-muted">
                    @Model.TotalReviews yorum
                </small>
            </div>
        </div>
    </div>
</div>

<!-- Hızlı Erişim Butonları -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <a asp-page="/Instructor/CreateCourse" class="btn btn-primary w-100 py-3 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Yeni Kurs Oluştur
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Instructor/Courses" class="btn btn-outline-primary w-100 py-3 shadow-sm">
            <i class="bi bi-book me-2"></i> Kurslarımı Görüntüle
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Instructor/Analytics" class="btn btn-outline-secondary w-100 py-3 shadow-sm">
            <i class="bi bi-graph-up me-2"></i> Detaylı İstatistikler
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Son Eklenen Kurslar -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Son Eklenen Kurslar</h5>
                    <a asp-page="/Instructor/Courses" class="btn btn-sm btn-link">Tümünü Gör</a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.RecentCourses != null && Model.RecentCourses.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Kurs Adı</th>
                                    <th>Kategori</th>
                                    <th>Fiyat</th>
                                    <th>Durum</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in Model.RecentCourses)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@course.ImageUrl" alt="@course.Name"
                                                     class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                <div>
                                                    <div class="fw-semibold">@course.Name</div>
                                                    <small class="text-muted">@course.FormattedDuration</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@course.CategoryName</span>
                                        </td>
                                        <td class="fw-semibold text-primary">@course.FormattedPrice</td>
                                        <td>
                                            <span class="badge bg-success">Aktif</span>
                                        </td>
                                        <td>
                                            <a asp-page="/Instructor/UpdateCourse" asp-route-id="@course.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-3">Henüz hiç kursunuz bulunmuyor.</p>
                        <a asp-page="/Instructor/CreateCourse" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> İlk Kursunuzu Oluşturun
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Aktivite Akışı -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="mb-0 fw-bold">Son Aktiviteler</h5>
            </div>
            <div class="card-body">
                <div class="activity-feed">
                    <div class="activity-item d-flex mb-3 pb-3 border-bottom">
                        <div class="activity-icon bg-success bg-opacity-10 rounded-circle p-2 me-3">
                            <i class="bi bi-person-plus text-success"></i>
                        </div>
                        <div>
                            <p class="mb-1 small"><strong>Yeni öğrenci kaydı</strong></p>
                            <p class="mb-0 text-muted small">Ahmet Yılmaz kursunuza kayıt oldu</p>
                            <small class="text-muted">2 saat önce</small>
                        </div>
                    </div>

                    <div class="activity-item d-flex mb-3 pb-3 border-bottom">
                        <div class="activity-icon bg-warning bg-opacity-10 rounded-circle p-2 me-3">
                            <i class="bi bi-star-fill text-warning"></i>
                        </div>
                        <div>
                            <p class="mb-1 small"><strong>Yeni yorum</strong></p>
                            <p class="mb-0 text-muted small">Kursunuza 5 yıldız verildi</p>
                            <small class="text-muted">5 saat önce</small>
                        </div>
                    </div>

                    <div class="activity-item d-flex mb-3 pb-3 border-bottom">
                        <div class="activity-icon bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                            <i class="bi bi-cash text-primary"></i>
                        </div>
                        <div>
                            <p class="mb-1 small"><strong>Ödeme alındı</strong></p>
                            <p class="mb-0 text-muted small">350 ₺ hesabınıza aktarıldı</p>
                            <small class="text-muted">1 gün önce</small>
                        </div>
                    </div>

                    <div class="activity-item d-flex">
                        <div class="activity-icon bg-info bg-opacity-10 rounded-circle p-2 me-3">
                            <i class="bi bi-book text-info"></i>
                        </div>
                        <div>
                            <p class="mb-1 small"><strong>Kurs tamamlandı</strong></p>
                            <p class="mb-0 text-muted small">3 öğrenci kursu tamamladı</p>
                            <small class="text-muted">2 gün önce</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
