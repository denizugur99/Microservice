@page
@model MicroserviceWebApp.Pages.Auth.AccessDeniedModel
@{
    ViewData["Title"] = "Erişim Engellendi";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-danger">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-shield-exclamation text-danger" viewBox="0 0 16 16">
                            <path d="M5.338 1.59a61.44 61.44 0 0 0-2.837.856.481.481 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.725 10.725 0 0 0 2.287 2.233c.346.244.652.42.893.533.12.057.218.095.293.118a.55.55 0 0 0 .101.025.615.615 0 0 0 .1-.025c.076-.023.174-.061.294-.118.24-.113.547-.29.893-.533a10.726 10.726 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.775 11.775 0 0 1-2.517 2.453 7.159 7.159 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7.158 7.158 0 0 1-1.048-.625 11.777 11.777 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 62.456 62.456 0 0 1 5.072.56z"/>
                            <path d="M7.001 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.553.553 0 0 1-1.1 0z"/>
                        </svg>
                    </div>

                    <h2 class="card-title text-danger mb-3">Erişim Engellendi</h2>

                    <p class="lead mb-4">
                        Bu sayfaya erişim yetkiniz bulunmamaktadır.
                    </p>

                    @if (!string.IsNullOrEmpty(Model.ReturnUrl))
                    {
                        <div class="alert alert-warning" role="alert">
                            <strong>Gerekli Yetki:</strong> Bu sayfayı görüntülemek için gerekli role sahip değilsiniz.
                        </div>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <p class="text-muted mb-4">
                            <strong>Kullanıcı:</strong> @User.Identity.Name<br />
                            <strong>Roller:</strong> @string.Join(", ", User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))
                        </p>
                    }
                    else
                    {
                        <p class="text-muted mb-4">
                            Bu sayfaya erişmek için lütfen giriş yapın.
                        </p>
                    }

                    <div class="d-grid gap-2 col-md-8 mx-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="/" class="btn btn-primary btn-lg">Ana Sayfaya Dön</a>
                            <button onclick="history.back()" class="btn btn-outline-secondary">Geri Dön</button>
                        }
                        else
                        {
                            <a href="/Auth/SignIn?returnUrl=@Model.ReturnUrl" class="btn btn-primary btn-lg">Giriş Yap</a>
                            <a href="/" class="btn btn-outline-secondary">Ana Sayfaya Dön</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
