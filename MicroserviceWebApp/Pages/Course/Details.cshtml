@page "{id:guid}"
@model MicroserviceWebApp.Pages.Course.CourseDetailsModel
@{
    ViewData["Title"] = Model.Course?.Name ?? "Kurs Detayı";
}

<div class="container my-5">
    @if (Model.Course == null)
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle"></i> Kurs bulunamadı.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <course-picture src="@Model.Course.ImageUrl" class="card-img-top" style="height: 400px; object-fit: cover;" />
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h2 class="card-title fw-bold">@Model.Course.Name</h2>
                                <span class="badge bg-secondary">@Model.Course.Category.Name</span>
                            </div>
                            <div class="text-end">
                                <div class="text-warning fw-bold fs-5">@Model.Course.Feature.Rating.ToString("F1") ⭐</div>
                                <small class="text-muted">@Model.Course.Feature.Duration saat</small>
                            </div>
                        </div>

                        <p class="card-text">@Model.Course.Description</p>

                        <hr />

                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="fw-bold mb-3">Kurs Özellikleri</h5>
                                <ul class="list-unstyled">
                                    <li class="mb-2">
                                        <i class="bi bi-person text-primary"></i>
                                        <strong>Eğitmen:</strong> @Model.Course.Feature.EducatorFullName
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-clock text-primary"></i>
                                        <strong>Süre:</strong> @Model.Course.Feature.Duration saat
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-star text-warning"></i>
                                        <strong>Değerlendirme:</strong> @Model.Course.Feature.Rating.ToString("F1") / 5.0
                                    </li>
                                   
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top: 20px;">
                    <div class="card-body">
                        <h3 class="text-primary fw-bold mb-3">$@Model.Course.Price.ToString("N2")</h3>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button type="button" class="btn btn-success btn-lg w-100 mb-3">
                                <i class="bi bi-cart-plus"></i> Sepete Ekle
                            </button>
                         
                        }
                        else
                        {
                            <a asp-page="/Auth/SignIn" class="btn btn-primary btn-lg w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Giriş Yapın
                            </a>
                            <p class="text-muted small text-center mt-2">Satın almak için giriş yapmalısınız</p>
                        }

                        <hr class="my-4" />

                        <h5 class="fw-bold mb-3">Bu Kursta</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <i class="bi bi-check-circle text-success"></i>
                                @Model.Course.Feature.Duration saat video içerik
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle text-success"></i>
                                Sınırsız erişim
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle text-success"></i>
                                Tamamlama sertifikası
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
