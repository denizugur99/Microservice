@page
@model MicroserviceWebApp.Pages.Course.CourseIndexModel
@{
    ViewData["Title"] = "Tüm Kurslar";
}

<div class="container my-5">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold">Tüm Kurslar</h2>
            <p class="text-muted">Öğrenmeye başlamak için bir kurs seçin</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-@(Model.Message.Contains("başarıyla") ? "success" : "warning") alert-dismissible fade show" role="alert">
            <i class="bi bi-@(Model.Message.Contains("başarıyla") ? "check-circle" : "exclamation-triangle")"></i> @Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.CoursesViewModel == null || !Model.CoursesViewModel.Any())
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> Henüz hiç kurs bulunmuyor.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var course in Model.CoursesViewModel)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <course-picture src="@course.ImageUrl" class="card-img-top" style="height: 180px; object-fit: cover;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@course.Name</h5>
                            <p class="card-text text-muted small">@course.Description</p>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="badge bg-secondary">@course.CategoryName</span>
                                    <span class="text-warning fw-bold">@course.FormattedRating</span>
                                </div>

                                <div class="mb-2">
                                    <small class="text-muted">
                                        <i class="bi bi-clock"></i> @course.FormattedDuration
                                    </small>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="h5 mb-0 text-primary">@course.FormattedPrice</span>
                                    <div class="d-flex gap-1">
                                        <a asp-page="/Course/Details" asp-route-id="@course.Id" class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-eye"></i> Detay
                                        </a>
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            @if (Model.CurrentUserId.HasValue && Model.CurrentUserId.Value == course.UserId)
                                            {
                                                <span class="badge bg-info text-white align-self-center">Sizin Kursunuz</span>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="AddToBasket" class="d-inline">
                                                    <input type="hidden" name="courseId" value="@course.Id" />
                                                    <input type="hidden" name="courseName" value="@course.Name" />
                                                    <input type="hidden" name="coursePrice" value="@course.Price" />
                                                    <input type="hidden" name="imageUrl" value="@course.ImageUrl" />
                                                    <input type="hidden" name="userId" value="@course.UserId" />
                                                    <button type="submit" class="btn btn-success btn-sm">
                                                        <i class="bi bi-cart-plus"></i> Sepete Ekle
                                                    </button>
                                                </form>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
