<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Budemy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MicroserviceWebApp.styles.css" asp-append-version="true" />
    <style>
        :root {
            --budemy-primary: #5624d0;
            --budemy-primary-dark: #401b9c;
            --budemy-secondary: #a435f0;
            --budemy-accent: #f3722c;
            --budemy-success: #0f7c90;
            --budemy-dark: #1c1d1f;
            --budemy-light: #f7f9fa;
        }

        .navbar-budemy {
            background: linear-gradient(135deg, var(--budemy-primary) 0%, var(--budemy-secondary) 100%);
            box-shadow: 0 2px 10px rgba(86, 36, 208, 0.1);
            padding: 1rem 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.75rem;
            color: white !important;
            letter-spacing: -0.5px;
        }

        .navbar-brand:hover {
            color: #f0f0f0 !important;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            transition: all 0.3s ease;
        }

        .nav-link:hover {
            color: white !important;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
        }

        .dropdown-toggle::after {
            margin-left: 0.5rem;
        }

        .dropdown-menu {
            border: none;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            border-radius: 8px;
            padding: 0.5rem;
        }

        .dropdown-item {
            padding: 0.75rem 1.25rem;
            border-radius: 6px;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .dropdown-item:hover {
            background: var(--budemy-light);
            color: var(--budemy-primary);
        }

        .dropdown-item i {
            width: 20px;
            margin-right: 8px;
        }

        .btn-basket {
            background: var(--budemy-accent);
            color: white;
            border: none;
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-basket:hover {
            background: #e85d0d;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(243, 114, 44, 0.3);
        }

        footer {
            background: var(--budemy-dark);
            color: rgba(255, 255, 255, 0.7);
            padding: 2rem 0;
            margin-top: auto;
        }

        footer a {
            color: var(--budemy-secondary);
            text-decoration: none;
        }

        footer a:hover {
            color: white;
        }

        body {
            background: #fafbfc;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
        }

        .navbar-toggler {
            border-color: rgba(255, 255, 255, 0.5);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 255, 255, 0.8%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-budemy">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <i class="bi bi-mortarboard-fill"></i> Budemy
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">
                                <i class="bi bi-house-door"></i> Ana Sayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Course/Index">
                                <i class="bi bi-book"></i> Kurslar
                            </a>
                        </li>
                        @if (User.IsInRole("instructor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Instructor/Index">
                                    <i class="bi bi-person-video3"></i> Eğitmen
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-basket" asp-page="/Basket/Basket">
                                    <i class="bi bi-cart3"></i> Sepet
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Basket/Basket">
                                            <i class="bi bi-cart3"></i> Sepetim
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page="/Auth/SignIn" asp-page-handler="SignOut">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/SignUp">
                                    <i class="bi bi-person-plus"></i> Kayıt Ol
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/SignIn">
                                    <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="text-white mb-3">
                        <i class="bi bi-mortarboard-fill"></i> Budemy
                    </h5>
                    <p class="mb-0">Online eğitim platformu ile kariyerinizi geliştirin.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0">
                        &copy; 2026 Budemy. Tüm hakları saklıdır.
                        <a asp-area="" asp-page="/Privacy">Gizlilik Politikası</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
